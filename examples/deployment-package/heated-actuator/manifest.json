      "notes": [
        "Test verification mode evaluates criteria against observed or fixture signals and does not command production control behavior."
      ]
    },
    {
      "id": "signal-validation",
      "purpose": "signal_validation",
      "uses_artifacts": [
        "test_verification_config",
        "channel_map"
      ],
      "notes": [
